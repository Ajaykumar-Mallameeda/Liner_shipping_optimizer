```gitignore
# =========================================================
# AI Vessel Routing System — .gitignore
# =========================================================

# ---------------------------------------------------------
# Python
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# ---------------------------------------------------------
# Virtual Environments
# ---------------------------------------------------------
venv/
.venv/
env/
ENV/

# ---------------------------------------------------------
# Environment Variables / Secrets
# ---------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------
.vscode/
.idea/
*.iml

# ---------------------------------------------------------
# OS Files
# ---------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------
# Logs / Runtime
# ---------------------------------------------------------
logs/*
!logs/.gitkeep

*.log
*.out
*.err
nohup.out

test_output.txt
server.log
pipeline.log
debug.log
_legacy/
*.html
*.pdf
*.db
analysis_output/
logs/
raw_responses/

# ---------------------------------------------------------
# Local Data / Generated Datasets
# ---------------------------------------------------------
data/*
!data/.gitkeep

# Optional:
# Keep if versioning only curated datasets
# !data/datasets/
# !data/datasets/*.json

# ---------------------------------------------------------
# Claude / Graphify / Tooling
# ---------------------------------------------------------
claude/
.claude/

graphify/
.graphify/
graphify-out/

# ---------------------------------------------------------
# Temporary / Scratch / Experiments
# ---------------------------------------------------------
tmp/
temp/
scratch/
sandbox/

# ---------------------------------------------------------
# Archived generated reports / diagnostics
# ---------------------------------------------------------
zunk/

# ---------------------------------------------------------
# Generated Reports (ignore anywhere)
# ---------------------------------------------------------
*_REPORT.md
*_AUDIT.md
*_SUMMARY.md
*_DIAGNOSTIC*.md
*_VALIDATION*.md

# ---------------------------------------------------------
# Jupyter / notebooks
# ---------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------
# Build / distribution
# ---------------------------------------------------------
build/
dist/
*.egg-info/

# ---------------------------------------------------------
# Local databases / cache
# ---------------------------------------------------------
*.sqlite3
*.db
.cache/

# ---------------------------------------------------------
# Test artifacts
# ---------------------------------------------------------
pytestdebug.log
.coverage.*
```
# Free Claude Code (any location)
/free-claude-code/
**/free-claude-code/

# ==========================
# Frontend Build
# ==========================

frontend/dist/
frontend/node_modules/

# Generated runtime outputs
frontend/evaluation_output.json

# Generated demo outputs
outputs/*.json
outputs/*.csv

# Runtime caches
frontend/.vite/

# macOS
.AppleDouble
.LSOverride

# Windows
ehthumbs.db

# Misc
*.tmp
*.bak
*.swp